# Anthropic Claude — used to refine pitch narratives in /api/improve-pitch
ANTHROPIC_API_KEY=sk-ant-...

# Resend — used to send contact form submissions in /api/contact
RESEND_API_KEY=re_...

# Comma-separated recipients for contact form submissions
